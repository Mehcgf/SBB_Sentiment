   "source": [
    "from transformers import pipeline\n",
    "\n",
    "# zero-shot classifier laden\n",
    "# funktioniert ohne training — kategorien werden selbst definiert\n",
    "zero_shot = pipeline(\n",
    "    \"zero-shot-classification\",\n",
    "    model=\"facebook/bart-large-mnli\"\n",
    ")\n",
    "\n",
    "# themen die wir testen wollen — abgeleitet aus der wordcloud\n",
    "kategorien = [\"Preis\", \"App\", \"Verspätung\", \"Kundenservice\", \"Komfort\", \"Ticket\"]\n",
    "\n",
    "# auf alle bewertungen anwenden\n",
    "def klassifiziere(text):\n",
    "    result = zero_shot(text[:512], candidate_labels=kategorien)\n",
    "    return result[\"labels\"][0]  # beste kategorie zurückgeben\n",
    "\n",
    "df_clean[\"thema\"] = df_clean[\"Review Text\"].apply(klassifiziere)\n",
    "\n",
    "print(df_clean[\"thema\"].value_counts())"
   ]
  },
